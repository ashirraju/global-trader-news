# Kotak news feeds API
NEWS_API_URL=https://neo.kotaksecurities.com/api/1news/feeds
NEWS_FEED_MODE=all

# Cron schedule (default: every 2 minutes)
CRON_SCHEDULE=*/2 * * * *

# Local API server port
PORT=3000

# Timezone used in Telegram timestamps
TIME_ZONE=Asia/Kolkata

# Telegram — create a bot via @BotFather, then get chat id from @userinfobot
TELEGRAM_BOT_TOKEN=8971831775:AAHXFzuUcmOUotOlDUWB7v-8-v1zfY7H5zA
TELEGRAM_CHAT_ID=-1003854850968

# SQLite database path
DB_PATH=./data/news.db

# Set to true to log new articles without sending Telegram messages
DRY_RUN=false
